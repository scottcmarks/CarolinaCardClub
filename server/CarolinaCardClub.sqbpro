1" value="80"/><column index="2" value="69"/><column index="3" value="112"/><column index="4" value="89"/><column index="5" value="86"/><column index="6" value="102"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Session_Panel_List" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="1"/></sort><column_widths><column index="1" value="80"/><column index="2" value="69"/><column index="3" value="97"/><column index="4" value="89"/><column index="5" value="124"/><column index="6" value="148"/><column index="7" value="98"/><column index="8" value="78"/><column index="9" value="112"/><column index="10" value="148"/><column index="11" value="59"/><column index="12" value="60"/><column index="13" value="38"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Session_Rate_List" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="80"/><column index="2" value="69"/><column index="3" value="148"/><column index="4" value="145"/><column index="5" value="97"/><column index="6" value="102"/><column index="7" value="88"/><column index="8" value="126"/><column index="9" value="124"/><column index="10" value="38"/><column index="11" value="120"/><column index="12" value="78"/><column index="13" value="112"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Super_Bowl_Players" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="70"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="System_State" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="21"/><column index="2" value="98"/><column index="3" value="127"/><column index="4" value="154"/><column index="5" value="167"/><column index="6" value="173"/><column index="7" value="167"/><column index="8" value="202"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="91"/><column index="2" value="32"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT 
          p.Player_Id,
          IFNULL(p.NickName, p.Name) AS Name,
          pb.Balance,
          COALESCE(r.Rate, 0.0) AS Hourly_Rate,
          cat.Prepay_Hours AS Prepay_Hours,
          CASE WHEN s.Session_Id IS NOT NULL AND s.Stop_Epoch IS NULL THEN 1 ELSE 0 END AS Is_Active
      FROM Player p
      JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
      JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
      
      LEFT JOIN Rate_Interval ri ON p.Player_Category_Id = ri.Player_Category_Id 
          AND ? &gt;= ri.Start_Epoch 
          AND (? &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
      LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
      
      LEFT JOIN (
          SELECT Player_Id, MAX(Start_Epoch) AS Max_Start_Epoch 
          FROM Session 
          GROUP BY Player_Id
      ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
      LEFT JOIN Session s ON p.Player_Id = s.Player_Id AND s.Start_Epoch = max_sessions.Max_Start_Epoch
      
      ORDER BY 
          CASE 
              WHEN s.Start_Epoch IS NULL THEN 4
              WHEN s.Stop_Epoch IS NULL THEN 1
              WHEN (? - 1814400) &lt;= s.Stop_Epoch THEN 2
              ELSE 3
          END,
          IFNULL(p.NickName, p.Name)</sql><sql name="Edit View Player_Category_Rate_Interval_List">DROP VIEW IF EXISTS &quot;main&quot;.&quot;Player_Category_Rate_Interval_List&quot;;
CREATE VIEW &quot;Player_Category_Rate_Interval_List&quot; AS 
SELECT 
  cat.Player_Category_Id, 
  cat.Name, 
  ri.Start, 
  ri.Stop, 
  ri.Rate, 
  ri.Description 
FROM Player_Category as cat
JOIN Rate_Interval_List as ri 
WHERE cat.Rate_Interval_Id == ri.Rate_Interval_Id</sql><sql name="SQL 3">SELECT 
          p.Player_Id,
          IFNULL(p.NickName, p.Name) AS Name,
          pb.Balance,
          COALESCE(r.Rate, 0.0) AS Hourly_Rate,
          cat.Prepay_Hours AS Prepay_Hours,
          CASE WHEN s.Session_Id IS NOT NULL AND s.Stop_Epoch IS NULL THEN 1 ELSE 0 END AS Is_Active
      FROM Player p
      JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
      JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
      
      LEFT JOIN Rate_Interval ri ON p.Player_Category_Id = ri.Player_Category_Id 
          AND ? &gt;= ri.Start_Epoch 
          AND (? &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
      LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
      
      LEFT JOIN (
          SELECT Player_Id, MAX(Start_Epoch) AS Max_Start_Epoch 
          FROM Session 
          GROUP BY Player_Id
      ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
      LEFT JOIN Session s ON p.Player_Id = s.Player_Id AND s.Start_Epoch = max_sessions.Max_Start_Epoch
      
      ORDER BY 
          CASE 
              WHEN s.Start_Epoch IS NULL THEN 4
              WHEN s.Stop_Epoch IS NULL THEN 1
              WHEN (? - 1814400) &lt;= s.Stop_Epoch THEN 2
              ELSE 3
          END,
          IFNULL(p.NickName, p.Name)</sql><sql name="SQL 4*">SELECT 
          p.Player_Id,
          IFNULL(p.NickName, p.Name) AS Name,
          pb.Balance,
          COALESCE(r.Rate, 0.0) AS Hourly_Rate,
          cat.Prepay_Hours AS Prepay_Hours,
          CASE WHEN s.Session_Id IS NOT NULL AND s.Stop_Epoch IS NULL THEN 1 ELSE 0 END AS Is_Active
      FROM Player p
      JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
      JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
      
      -- THE BRIDGE: Walk from Category -&gt; Bridging Table -&gt; Time Interval
      LEFT JOIN Category_Rate_Interval cri ON cat.Player_Category_Id = cri.Player_Category_Id
      LEFT JOIN Rate_Interval ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id 
          AND ? &gt;= ri.Start_Epoch 
          AND (? &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
      LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
      
      LEFT JOIN (
          SELECT Player_Id, MAX(Start_Epoch) AS Max_Start_Epoch 
          FROM Session 
          GROUP BY Player_Id
      ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
      LEFT JOIN Session s ON p.Player_Id = s.Player_Id AND s.Start_Epoch = max_sessions.Max_Start_Epoch
      
      ORDER BY 
          CASE 
              WHEN s.Start_Epoch IS NULL THEN 4
              WHEN s.Stop_Epoch IS NULL THEN 1
              WHEN (? - 1814400) &lt;= s.Stop_Epoch THEN 2
              ELSE 3
          END,
          IFNULL(p.NickName, p.Name)</sql><sql name="Edit View Player_Selection_List*">DROP VIEW IF EXISTS &quot;main&quot;.&quot;Player_Selection_List&quot;;
CREATE VIEW &quot;Player_Selection_List&quot; AS
SELECT 
    p.Player_Id,
    IFNULL(p.NickName, p.Name) AS Name,
    pb.Balance,
    ri.Rate AS Hourly_Rate,
    cat.Prepay_Hours AS Prepay_Hours,
    CASE WHEN s.Session_Id IS NOT NULL THEN 1 ELSE 0 END AS Is_Active
FROM 
    Player p
JOIN 
    Player_Balance pb ON p.Player_Id = pb.Player_Id
JOIN 
    Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
JOIN 
    Player_Category_Rate_Interval_List ri ON p.Player_Category_Id = ri.Player_Category_Id
LEFT JOIN 
    (
        -- FIXED: Use MAX(Session_Id) to guarantee a unique 1:1 match
        SELECT 
            Player_Id,
            MAX(Session_Id) AS Max_Session_Id
        FROM 
            Session
        GROUP BY 
            Player_Id
    ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
LEFT JOIN 
    -- FIXED: Join directly on the unique Primary Key
    Session s ON max_sessions.Max_Session_Id = s.Session_Id
GROUP BY 
    p.Player_Id
ORDER BY 
    CASE 
        WHEN s.Start_Epoch IS NULL THEN 4
        WHEN s.Stop_Epoch IS NULL THEN 1
        WHEN strftime('%s', 'now', '-21 days') &lt;= s.Stop_Epoch THEN 2
        ELSE 3
    END,
	p.Player_Category_Id,
    IFNULL(p.NickName, p.Name)</sql><current_tab id="4"/></tab_sql></sqlb_project>
