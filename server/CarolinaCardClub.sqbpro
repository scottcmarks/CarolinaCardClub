ew_pk="_rowid_" freeze_columns="0"><sort><column index="3" mode="1"/></sort><column_widths><column index="1" value="80"/><column index="2" value="69"/><column index="3" value="112"/><column index="4" value="89"/><column index="5" value="86"/><column index="6" value="102"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Session_Panel_List" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="1"/></sort><column_widths><column index="1" value="80"/><column index="2" value="69"/><column index="3" value="97"/><column index="4" value="89"/><column index="5" value="124"/><column index="6" value="148"/><column index="7" value="98"/><column index="8" value="78"/><column index="9" value="112"/><column index="10" value="148"/><column index="11" value="59"/><column index="12" value="60"/><column index="13" value="38"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Session_Rate_List" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="80"/><column index="2" value="69"/><column index="3" value="148"/><column index="4" value="145"/><column index="5" value="97"/><column index="6" value="102"/><column index="7" value="88"/><column index="8" value="126"/><column index="9" value="124"/><column index="10" value="38"/><column index="11" value="120"/><column index="12" value="78"/><column index="13" value="112"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Super_Bowl_Players" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="70"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="System_State" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="21"/><column index="2" value="98"/><column index="3" value="127"/><column index="4" value="154"/><column index="5" value="167"/><column index="6" value="173"/><column index="7" value="167"/><column index="8" value="202"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="91"/><column index="2" value="32"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT 
          p.Player_Id,
          IFNULL(p.NickName, p.Name) AS Name,
          pb.Balance,
          COALESCE(r.Rate, 0.0) AS Hourly_Rate,
          cat.Prepay_Hours AS Prepay_Hours,
          CASE WHEN s.Session_Id IS NOT NULL AND s.Stop_Epoch IS NULL THEN 1 ELSE 0 END AS Is_Active
      FROM Player p
      JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
      JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
      
      LEFT JOIN Rate_Interval ri ON p.Player_Category_Id = ri.Player_Category_Id 
          AND ? &gt;= ri.Start_Epoch 
          AND (? &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
      LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
      
      LEFT JOIN (
          SELECT Player_Id, MAX(Start_Epoch) AS Max_Start_Epoch 
          FROM Session 
          GROUP BY Player_Id
      ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
      LEFT JOIN Session s ON p.Player_Id = s.Player_Id AND s.Start_Epoch = max_sessions.Max_Start_Epoch
      
      ORDER BY 
          CASE 
              WHEN s.Start_Epoch IS NULL THEN 4
              WHEN s.Stop_Epoch IS NULL THEN 1
              WHEN (? - 1814400) &lt;= s.Stop_Epoch THEN 2
              ELSE 3
          END,
          IFNULL(p.NickName, p.Name)</sql><sql name="Edit View Player_Category_Rate_Interval_List">DROP VIEW IF EXISTS &quot;main&quot;.&quot;Player_Category_Rate_Interval_List&quot;;
CREATE VIEW &quot;Player_Category_Rate_Interval_List&quot; AS 
SELECT 
  cat.Player_Category_Id, 
  cat.Name, 
  ri.Start, 
  ri.Stop, 
  ri.Rate, 
  ri.Description 
FROM Player_Category as cat
JOIN Rate_Interval_List as ri 
WHERE cat.Rate_Interval_Id == ri.Rate_Interval_Id</sql><sql name="SQL 3">SELECT 
          p.Player_Id,
          IFNULL(p.NickName, p.Name) AS Name,
          pb.Balance,
          COALESCE(r.Rate, 0.0) AS Hourly_Rate,
          cat.Prepay_Hours AS Prepay_Hours,
          CASE WHEN s.Session_Id IS NOT NULL AND s.Stop_Epoch IS NULL THEN 1 ELSE 0 END AS Is_Active
      FROM Player p
      JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
      JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
      
      LEFT JOIN Rate_Interval ri ON p.Player_Category_Id = ri.Player_Category_Id 
          AND ? &gt;= ri.Start_Epoch 
          AND (? &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
      LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
      
      LEFT JOIN (
          SELECT Player_Id, MAX(Start_Epoch) AS Max_Start_Epoch 
          FROM Session 
          GROUP BY Player_Id
      ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
      LEFT JOIN Session s ON p.Player_Id = s.Player_Id AND s.Start_Epoch = max_sessions.Max_Start_Epoch
      
      ORDER BY 
          CASE 
              WHEN s.Start_Epoch IS NULL THEN 4
              WHEN s.Stop_Epoch IS NULL THEN 1
              WHEN (? - 1814400) &lt;= s.Stop_Epoch THEN 2
              ELSE 3
          END,
          IFNULL(p.NickName, p.Name)</sql><sql name="SQL 4">SELECT 
          p.Player_Id,
          IFNULL(p.NickName, p.Name) AS Name,
          pb.Balance,
          COALESCE(r.Rate, 0.0) AS Hourly_Rate,
          cat.Prepay_Hours AS Prepay_Hours,
          CASE WHEN s.Session_Id IS NOT NULL AND s.Stop_Epoch IS NULL THEN 1 ELSE 0 END AS Is_Active
      FROM Player p
      JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
      JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
      
      -- THE BRIDGE: Walk from Category -&gt; Bridging Table -&gt; Time Interval
      LEFT JOIN Category_Rate_Interval cri ON cat.Player_Category_Id = cri.Player_Category_Id
      LEFT JOIN Rate_Interval ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id 
          AND ? &gt;= ri.Start_Epoch 
          AND (? &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
      LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
      
      LEFT JOIN (
          SELECT Player_Id, MAX(Start_Epoch) AS Max_Start_Epoch 
          FROM Session 
          GROUP BY Player_Id
      ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
      LEFT JOIN Session s ON p.Player_Id = s.Player_Id AND s.Start_Epoch = max_sessions.Max_Start_Epoch
      
      ORDER BY 
          CASE 
              WHEN s.Start_Epoch IS NULL THEN 4
              WHEN s.Stop_Epoch IS NULL THEN 1
              WHEN (? - 1814400) &lt;= s.Stop_Epoch THEN 2
              ELSE 3
          END,
          IFNULL(p.NickName, p.Name)</sql><sql name="Edit View Player_Selection_List">DROP VIEW IF EXISTS &quot;main&quot;.&quot;Player_Selection_List&quot;;
CREATE VIEW &quot;Player_Selection_List&quot; AS
SELECT 
    p.Player_Id,
    IFNULL(p.NickName, p.Name) AS Name,
    pb.Balance,
    ri.Rate AS Hourly_Rate,
    cat.Prepay_Hours AS Prepay_Hours,
    CASE WHEN s.Session_Id IS NOT NULL THEN 1 ELSE 0 END AS Is_Active
FROM 
    Player p
JOIN 
    Player_Balance pb ON p.Player_Id = pb.Player_Id
JOIN 
    Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
JOIN 
    Player_Category_Rate_Interval_List ri ON p.Player_Category_Id = ri.Player_Category_Id
LEFT JOIN 
    (
        -- FIXED: Use MAX(Session_Id) to guarantee a unique 1:1 match
        SELECT 
            Player_Id,
            MAX(Session_Id) AS Max_Session_Id
        FROM 
            Session
        GROUP BY 
            Player_Id
    ) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
LEFT JOIN 
    -- FIXED: Join directly on the unique Primary Key
    Session s ON max_sessions.Max_Session_Id = s.Session_Id
GROUP BY 
    p.Player_Id
ORDER BY 
    CASE 
        WHEN s.Start_Epoch IS NULL THEN 4
        WHEN s.Stop_Epoch IS NULL THEN 1
        WHEN strftime('%s', 'now', '-21 days') &lt;= s.Stop_Epoch THEN 2
        ELSE 3
    END,
	p.Player_Category_Id,
    IFNULL(p.NickName, p.Name)</sql><sql name="SQL 6*">BEGIN TRANSACTION;

-- 1. Create the Bridging Table to remember history
CREATE TABLE IF NOT EXISTS Category_Rate_Interval (
    Player_Category_Id INTEGER NOT NULL,
    Rate_Interval_Id INTEGER NOT NULL,
    PRIMARY KEY (Player_Category_Id, Rate_Interval_Id)
);

-- 2. Populate the ordered pairs! 
-- This gives Regular (3) and Reduced (4) access to both their old AND new time intervals
INSERT OR IGNORE INTO Category_Rate_Interval (Player_Category_Id, Rate_Interval_Id) VALUES 
(1, 1), -- Founder gets Free
(2, 1), -- Manager gets Free
(3, 3), -- Regular gets historical $5
(3, 5), -- Regular gets new $6
(4, 2), -- Reduced gets historical $3
(4, 4); -- Reduced gets new $4

-- 3. THE TIME-TRAVELING REPAIR
-- This reaches back through the new bridge, finds exactly what the rate WAS at the time 
-- the session started, and permanently burns it into the Session table's Hourly_Rate column.
UPDATE Session 
SET Hourly_Rate = IFNULL((
    SELECT r.Rate
    FROM Player p
    JOIN Category_Rate_Interval cri ON p.Player_Category_Id = cri.Player_Category_Id
    JOIN Rate_Interval ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id
    JOIN Rate r ON ri.Rate_Id = r.Rate_Id
    WHERE Session.Player_Id = p.Player_Id
      AND Session.Start_Epoch &gt;= ri.Start_Epoch 
      AND (Session.Start_Epoch &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
), Hourly_Rate)
WHERE Is_Prepaid = 0;

-- 4. SEVER THE VULNERABILITY
-- Rewrite the View so it strictly uses the locked-in Session.Hourly_Rate.
-- It will NEVER look at the live Category rates to calculate historical balances again.
DROP VIEW IF EXISTS &quot;Session_Rate_List&quot;;
CREATE VIEW &quot;Session_Rate_List&quot; AS
SELECT
    s.Session_Id, s.Player_Id, s.Start_Epoch as Session_Start_Epoch, s.Stop_Epoch as Session_Stop_Epoch,
    IFNULL(p.NickName,p.Name) as Name, c.Name as Category, c.Player_Category_Id as Category_Id,
    0 as Rate_Start_Epoch, 0 as Rate_Stop_Epoch, s.Hourly_Rate as Rate, 'Locked Rate' as Rate_Description,
    s.Is_Prepaid, s.Prepay_Amount
FROM Session as s
JOIN Player as p ON s.Player_Id == p.Player_Id
JOIN Player_Category as c ON p.Player_Category_Id == c.Player_Category_Id;

COMMIT;</sql><sql name="SQL 7*">BEGIN TRANSACTION;

-- 1. REWIRE PAYMENT VIEWS
-- Payments must now look at exactly when they occurred to find the right rate interval via the bridge.
DROP VIEW IF EXISTS &quot;Payment_Rate_Interval_Id_List&quot;;
CREATE VIEW &quot;Payment_Rate_Interval_Id_List&quot; AS 
SELECT 
  pmt.Player_Id as Player_Id, 
  IFNULL(p.NickName, p.Name) as Player_Name, 
  pmt.Epoch as Payment_Epoch, 
  pmt.Amount, 
  cri.Rate_Interval_Id as Rate_Interval_Id 
FROM Payment as pmt 
JOIN Player as p ON pmt.Player_Id = p.Player_Id
JOIN Player_Category as c ON p.Player_Category_Id = c.Player_Category_Id
JOIN Category_Rate_Interval as cri ON c.Player_Category_Id = cri.Player_Category_Id
JOIN Rate_Interval as ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id
WHERE pmt.Epoch &gt;= ri.Start_Epoch 
  AND (pmt.Epoch &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0);

DROP VIEW IF EXISTS &quot;Payment_Rate_List&quot;;
CREATE VIEW &quot;Payment_Rate_List&quot; AS 
SELECT 
  pmt.Player_Id as Player_Id, 
  pmt.Epoch as Payment_Epoch, 
  pmt.Amount, 
  cri.Rate_Interval_Id as Rate_Interval_Id, 
  r.Rate as Hourly_Rate, 
  r.Description as Rate_Description, 
  (pmt.Amount * 3600) / r.Rate as Purchased_Seconds, 
  CAST((pmt.Amount * 3600) / r.Rate / 3600 AS TEXT) || ':' || PRINTF('%02d', CAST(((pmt.Amount * 3600) / r.Rate % 3600) / 60 AS INTEGER)) AS formatted_time 
FROM Payment as pmt 
JOIN Player as p ON pmt.Player_Id = p.Player_Id
JOIN Player_Category as c ON p.Player_Category_Id = c.Player_Category_Id
JOIN Category_Rate_Interval cri ON c.Player_Category_Id = cri.Player_Category_Id
JOIN Rate_Interval ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id
JOIN Rate r ON ri.Rate_Id = r.Rate_Id
WHERE pmt.Epoch &gt;= ri.Start_Epoch 
  AND (pmt.Epoch &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0);

-- 2. REWIRE CATEGORY INTERVAL LIST
-- This simply lists all available intervals for a category by walking across the bridge.
DROP VIEW IF EXISTS &quot;Player_Category_Rate_Interval_List&quot;;
CREATE VIEW &quot;Player_Category_Rate_Interval_List&quot; AS 
SELECT 
  cat.Player_Category_Id, 
  cat.Name, 
  ri.Start, 
  ri.Stop, 
  ri.Rate, 
  ri.Description 
FROM Player_Category as cat
JOIN Category_Rate_Interval as cri ON cat.Player_Category_Id = cri.Player_Category_Id
JOIN Rate_Interval_List as ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id;

-- 3. REWIRE PLAYER SELECTION LIST
-- Even though your Dart server bypasses this view, we must fix it so viewing it in SQLite doesn't yield duplicate rows.
-- We force it to default to the real-world ticking clock.
DROP VIEW IF EXISTS &quot;Player_Selection_List&quot;;
CREATE VIEW &quot;Player_Selection_List&quot; AS
SELECT 
    p.Player_Id,
    IFNULL(p.NickName, p.Name) AS Name,
    pb.Balance,
    r.Rate AS Hourly_Rate,
    cat.Prepay_Hours AS Prepay_Hours,
    CASE WHEN s.Session_Id IS NOT NULL THEN 1 ELSE 0 END AS Is_Active
FROM Player p
JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id
LEFT JOIN Category_Rate_Interval cri ON cat.Player_Category_Id = cri.Player_Category_Id
LEFT JOIN Rate_Interval ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id 
    AND strftime('%s', 'now') &gt;= ri.Start_Epoch 
    AND (strftime('%s', 'now') &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id
LEFT JOIN (SELECT Player_Id, MAX(Session_Id) AS Max_Session_Id FROM Session GROUP BY Player_Id) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
LEFT JOIN Session s ON max_sessions.Max_Session_Id = s.Session_Id
GROUP BY p.Player_Id
ORDER BY 
    CASE 
        WHEN s.Start_Epoch IS NULL THEN 4
        WHEN s.Stop_Epoch IS NULL THEN 1
        WHEN strftime('%s', 'now', '-21 days') &lt;= s.Stop_Epoch THEN 2
        ELSE 3
    END,
    IFNULL(p.NickName, p.Name);

COMMIT;</sql><sql name="SQL 8*">BEGIN TRANSACTION;

-- 1. Add the &quot;Game Time&quot; column to the System_State table
ALTER TABLE System_State ADD COLUMN Current_Game_Epoch INTEGER;

-- Initialize it safely with the current real-world time
UPDATE System_State SET Current_Game_Epoch = strftime('%s', 'now') WHERE Id = 1;

-- 2. Rewrite the View to dynamically pull time from System_State
DROP VIEW IF EXISTS &quot;Player_Selection_List&quot;;
CREATE VIEW &quot;Player_Selection_List&quot; AS
SELECT 
    p.Player_Id,
    IFNULL(p.NickName, p.Name) AS Name,
    pb.Balance,
    r.Rate AS Hourly_Rate,
    cat.Prepay_Hours AS Prepay_Hours,
    CASE WHEN s.Session_Id IS NOT NULL THEN 1 ELSE 0 END AS Is_Active
FROM Player p
JOIN Player_Balance pb ON p.Player_Id = pb.Player_Id
JOIN Player_Category cat ON p.Player_Category_Id = cat.Player_Category_Id

-- THE MAGIC: Cross Join pulls in the single global state row so we can read the time
CROSS JOIN System_State ss 

LEFT JOIN Category_Rate_Interval cri ON cat.Player_Category_Id = cri.Player_Category_Id
LEFT JOIN Rate_Interval ri ON cri.Rate_Interval_Id = ri.Rate_Interval_Id 
    -- Filter the intervals based strictly on the Game Time!
    AND ss.Current_Game_Epoch &gt;= ri.Start_Epoch 
    AND (ss.Current_Game_Epoch &lt;= ri.Stop_Epoch OR ri.Stop_Epoch IS NULL OR ri.Stop_Epoch = 0)
LEFT JOIN Rate r ON ri.Rate_Id = r.Rate_Id

LEFT JOIN (SELECT Player_Id, MAX(Session_Id) AS Max_Session_Id FROM Session GROUP BY Player_Id) AS max_sessions ON p.Player_Id = max_sessions.Player_Id
LEFT JOIN Session s ON max_sessions.Max_Session_Id = s.Session_Id
GROUP BY p.Player_Id
ORDER BY 
    CASE 
        WHEN s.Start_Epoch IS NULL THEN 4
        WHEN s.Stop_Epoch IS NULL THEN 1
        -- 21 days = 1,814,400 seconds. This ensures list sorting respects Game Time!
        WHEN (ss.Current_Game_Epoch - 1814400) &lt;= s.Stop_Epoch THEN 2
        ELSE 3
    END,
    IFNULL(p.NickName, p.Name);

COMMIT;</sql><current_tab id="7"/></tab_sql></sqlb_project>
