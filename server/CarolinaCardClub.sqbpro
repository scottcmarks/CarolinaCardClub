ay_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="System_State" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="21"/><column index="2" value="98"/><column index="3" value="127"/><column index="4" value="154"/><column index="5" value="167"/><column index="6" value="173"/><column index="7" value="167"/><column index="8" value="202"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="91"/><column index="2" value="32"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT 
    Rate_Interval_Id,
    Rate_Id,
    Start_Epoch,
    strftime('%Y-%m-%d %I:%M %P', datetime(Start_Epoch, 'unixepoch', 'localtime')) AS Start_Readable,
    Stop_Epoch,
    CASE 
        WHEN Stop_Epoch = 0 OR Stop_Epoch IS NULL THEN 'Active'
        ELSE strftime('%Y-%m-%d %I:%M %P', datetime(Stop_Epoch, 'unixepoch', 'localtime')) 
    END AS Stop_Readable
FROM Rate_Interval;</sql><sql name="Edit View Rate_Interval_List*">DROP VIEW IF EXISTS &quot;main&quot;.&quot;Rate_Interval_List&quot;;
CREATE VIEW &quot;Rate_Interval_List&quot; AS
SELECT
    Rate_Interval.Rate_Interval_Id,
	strftime('%Y-%m-%d %I:%M %P', datetime(Rate_Interval.Start_Epoch, 'unixepoch')) as Start,
	strftime('%Y-%m-%d %I:%M %P', datetime(Rate_Interval.Stop_Epoch, 'unixepoch')) as Stop,
	Rate.Rate as Rate,
	Rate.Description
  FROM
    Rate_Interval
  LEFT JOIN
     Rate
WHERE
    Rate_Interval.Rate_Id == Rate.Rate_Id</sql><sql name="SQL 3*">BEGIN TRANSACTION;

-- 1. Cap the old rate intervals at the very end of Feb 28
UPDATE Rate_Interval
SET Stop_Epoch = 1772341199
WHERE Rate_Interval_Id IN (2, 3);

-- 2. Insert the new rate intervals starting exactly on Mar 1
INSERT INTO Rate_Interval (Rate_Id, Start_Epoch, Stop_Epoch)
VALUES 
  (4, 1772341200, 4102444799),
  (5, 1772341200, 4102444799);

COMMIT;</sql><sql name="Edit View Rate_Interval_List*">DROP VIEW IF EXISTS &quot;main&quot;.&quot;Rate_Interval_List&quot;;
CREATE VIEW &quot;Rate_Interval_List&quot; AS
SELECT
    Rate_Interval.Rate_Interval_Id,
	strftime('%Y-%m-%d %I:%M %P', datetime(Rate_Interval.Start_Epoch, 'unixepoch', 'localtime')) as Start,
	strftime('%Y-%m-%d %I:%M %P', datetime(Rate_Interval.Stop_Epoch, 'unixepoch', 'localtime')) as Stop,
	Rate.Rate as Rate,
	Rate.Description
  FROM
    Rate_Interval
  LEFT JOIN
     Rate
WHERE
    Rate_Interval.Rate_Id == Rate.Rate_Id</sql><current_tab id="3"/></tab_sql></sqlb_project>
