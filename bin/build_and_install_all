#!/bin/bash
set -e

REPO="$(cd "$(dirname "$0")/.." && pwd)"

echo "=== Building macOS (release) ==="
(cd "$REPO/client" && flutter build macos --release)

echo "=== Building Android APK (release) ==="
(cd "$REPO/client" && flutter build apk --release)

APK="$REPO/client/build/app/outputs/flutter-apk/app-release.apk"

echo "=== Installing to tablet k ==="
adb -s "$(tablet_id k)" install -r "$APK"

echo "=== Installing to tablet j ==="
adb -s "$(tablet_id j)" install -r "$APK"

echo "=== Done ==="
